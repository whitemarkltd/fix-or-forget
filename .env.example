# -----------------------------------------------------------------------------
# Fix or Forget — environment configuration
# Copy this file to `.env.local` and fill in real values before launch.
# Every value is optional; the site builds and runs with all of them blank.
# -----------------------------------------------------------------------------

# Canonical site URL (used for sitemap.xml, OpenGraph, canonical tags).
NEXT_PUBLIC_SITE_URL=https://fixorforget.example.com

# --- Affiliate tags -----------------------------------------------------------
# Back Market partner / marketplace tag appended to refurbished search links.
NEXT_PUBLIC_AFFILIATE_BACKMARKET_TAG=
# Amazon Renewed associates tag (fallback refurbished marketplace).
NEXT_PUBLIC_AFFILIATE_AMAZON_TAG=
# iFixit affiliate tag for DIY parts links.
NEXT_PUBLIC_AFFILIATE_IFIXIT_TAG=
# Trade-in / buyback service base URL + tag (e.g. a Gazelle/SellCell partner link).
NEXT_PUBLIC_AFFILIATE_TRADEIN_BASE_URL=https://www.sellcell.com/search/
NEXT_PUBLIC_AFFILIATE_TRADEIN_TAG=

# Which refurbished marketplace to prefer: "backmarket" | "amazon"
NEXT_PUBLIC_REFURB_MARKETPLACE=backmarket

# --- Analytics (privacy-friendly, cookieless) --------------------------------
# Plausible or Umami script URL + site/website id. Leave blank to disable.
NEXT_PUBLIC_ANALYTICS_SCRIPT_URL=
NEXT_PUBLIC_ANALYTICS_SITE_ID=

# --- Feedback widget ----------------------------------------------------------
# Server-side webhook the feedback API route forwards submissions to.
# Any form-capture endpoint works (Formspree, a Google Apps Script webhook, etc).
# NOT public — read only in the serverless function.
FEEDBACK_WEBHOOK_URL=
